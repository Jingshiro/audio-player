# 服务端口
FRONTEND_PORT=8080
BACKEND_PORT=3000

# 后端配置（模式 B）
DATABASE_URL=file:./data/audio.db
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=500  # MB（长音频文件较大）

# CORS 配置（逗号分隔多个域名）
# 必须包含你的域名，否则 APP 无法连接服务器
# 例如: https://your-domain.com,https://localhost,capacitor://localhost
CORS_ORIGIN=https://your-domain.com,https://localhost,capacitor://localhost

# AI 配置（可选，用户也可在界面配置）
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o

# 破限词配置（可选，用户也可在界面配置）
DEFAULT_STT_PROMPT=
DEFAULT_TRANSLATE_PROMPT=
